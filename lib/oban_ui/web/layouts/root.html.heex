<!DOCTYPE html>
<html lang="en" data-theme="system">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={Plug.CSRFProtection.get_csrf_token()} />
    <title>{assigns[:page_title] || "Oban UI"}</title>
    <link rel="stylesheet" href={css_url(assigns[:base_path])} />
    <script defer src={js_url(assigns[:base_path])}></script>
  </head>
  <body class="oban-ui-root">
    {@inner_content}
  </body>
</html>
