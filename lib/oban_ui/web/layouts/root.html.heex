<!DOCTYPE html>
<html lang="en" data-theme="system">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={Plug.CSRFProtection.get_csrf_token()} />
    <title>{assigns[:page_title] || "Oban UI"}</title>
    <link rel="stylesheet" href={css_url(assigns[:base_path])} nonce={assigns[:csp_nonce]} />
    <script defer src={js_url(assigns[:base_path])} nonce={assigns[:csp_nonce]}></script>
  </head>
  <body class="oban-ui-root">
    <div
      id="oban-ui-connectivity"
      class="hidden phx-disconnected:flex fixed top-0 inset-x-0 z-50 items-center justify-center gap-2 bg-amber-500 text-amber-950 text-sm py-1"
      role="status"
      aria-live="polite"
    >
      <span aria-hidden="true">⚠</span>
      Reconnecting to server…
    </div>

    <a
      href="#oban-ui-main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:px-3 focus:py-1 focus:rounded-md focus:bg-oban-700 focus:text-white"
    >
      Skip to main content
    </a>

    {@inner_content}
  </body>
</html>
